# Meet42 — variables d'environnement
# Copier en .env.local (dev) et configurer les mêmes clés sur Vercel (prod).

# URL publique du site (SEO / Open Graph). Ex: https://ton-domaine.com ou http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# Supabase (optionnel — sans NEXT_PUBLIC_SUPABASE_URL + ANON_KEY, l'app tourne en mode mock local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Côté serveur uniquement (API routes) — clé service_role, ne JAMAIS exposer au client ni committer
SUPABASE_SERVICE_ROLE_KEY=

# Email de contact affiché dans l'app (footer / pages légales)
NEXT_PUBLIC_CONTACT_EMAIL=

# OAuth Facebook : "true" pour afficher le bouton (ne pas activer tant que l'app Meta / Supabase n'est pas prête)
# NEXT_PUBLIC_ENABLE_FACEBOOK_LOGIN=true

# Notes schéma Supabase :
# - Storage : bucket public « avatars » pour les photos de profil (Dashboard → Storage → New bucket → public)
# - Table « profiles » : colonne « photo_urls » de type text[] (3 à 6 photos) en plus de « photo_url » (1ʳᵉ image, pour les cartes)
